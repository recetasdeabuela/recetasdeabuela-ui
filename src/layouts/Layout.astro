---
import '../styles/global.css';
import { UtensilsCrossed, Mic, Heart } from '@lucide/astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = 'Un tesoro de recetas tradicionales españolas, preservando la memoria culinaria de nuestras abuelas.',
  image,
  imageAlt = 'Recetas de Abuela — cocina tradicional española',
  type = 'website',
  jsonLd,
} = Astro.props;

const siteTitle = 'Recetas de Abuela';
const siteDescription = 'Un tesoro de recetas tradicionales españolas, preservando la memoria culinaria de nuestras abuelas.';
const fullTitle = title === siteTitle ? title : `${title} — ${siteTitle}`;

const siteBase = Astro.site ?? new URL('http://localhost:4321');
const canonicalURL = new URL(Astro.url.pathname, siteBase);

function toAbsoluteUrl(url: string | undefined): string {
  if (!url) return new URL('/og-default.jpg', siteBase).toString();
  if (url.startsWith('http://') || url.startsWith('https://')) return url;
  return new URL(url, siteBase).toString();
}
const ogImage = toAbsoluteUrl(image);

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteBase}#website`,
  name: siteTitle,
  description: siteDescription,
  url: siteBase.toString(),
  inLanguage: 'es-ES',
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content={siteTitle} />

    <!-- summary_large_image muestra la imagen grande al compartir -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body class="flex flex-col min-h-screen">
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

    <div
      id="dev-banner"
      role="status"
      aria-live="polite"
      class="bg-amber-100 border-b-2 border-amber-300 text-amber-900 text-sm no-print"
    >
      <div class="max-w-5xl mx-auto px-4 py-3 flex items-start justify-between gap-4">
        <p class="leading-snug">
          <strong class="font-bold">Sitio en desarrollo.</strong>
          Las recetas y perfiles de cocineras que aparecen ahora mismo han sido generados por IA como contenido de prueba.
          El contenido real, con recetas auténticas y sus protagonistas, se irá publicando próximamente.
        </p>
        <button
          type="button"
          id="close-dev-banner"
          class="flex-shrink-0 p-1 rounded-lg hover:bg-amber-200 transition-colors"
          aria-label="Cerrar aviso de desarrollo"
          style="min-width: 2rem; min-height: 2rem;"
        >
          <span aria-hidden="true" class="text-lg leading-none">×</span>
        </button>
      </div>
    </div>

    <script>
      const banner = document.getElementById('dev-banner');
      const closeBtn = document.getElementById('close-dev-banner');

      if (sessionStorage.getItem('devBannerClosed')) {
        banner?.classList.add('hidden');
      }

      closeBtn?.addEventListener('click', () => {
        banner?.classList.add('hidden');
        sessionStorage.setItem('devBannerClosed', '1');
      });
    </script>

    <header
      class="bg-[var(--color-earth-900)] text-white shadow-lg"
      role="banner"
    >
      <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between gap-4 flex-wrap">
        <a
          href="/"
          class="flex items-center gap-3 hover:opacity-90 transition-opacity"
          aria-label="Recetas de Abuela — Ir a la página principal"
        >
          <UtensilsCrossed size={32} aria-hidden="true" class="text-amber-300" />
          <div>
            <span
              class="block text-xl font-bold tracking-wide"
              style="font-family: var(--font-serif);"
            >
              Recetas de Abuela
            </span>
            <span class="block text-xs text-amber-300 tracking-widest uppercase">
              Cocina tradicional española
            </span>
          </div>
        </a>

        <nav aria-label="Navegación principal">
          <ul class="flex items-center gap-1 list-none m-0 p-0">
            <li>
              <a
                href="/"
                class="px-4 py-2 rounded-lg text-sm font-medium hover:bg-white/10 transition-colors"
                aria-current={Astro.url.pathname === '/' ? 'page' : undefined}
              >
                Recetas
              </a>
            </li>
            <li>
              <a
                href="/sobre-el-proyecto"
                class="px-4 py-2 rounded-lg text-sm font-medium hover:bg-white/10 transition-colors"
                aria-current={Astro.url.pathname === '/sobre-el-proyecto' ? 'page' : undefined}
              >
                El Proyecto
              </a>
            </li>
            <li>
              <a
                href="/sobre-el-proyecto#manda-tu-receta"
                class="ml-2 flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-bold bg-[var(--color-terracotta-500)] hover:bg-[var(--color-terracotta-600)] text-white transition-colors"
                style="min-height: var(--min-touch-target);"
              >
                <Mic size={16} aria-hidden="true" />
                ¡Manda tu receta!
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <main id="main-content" tabindex="-1" class="flex-1">
      <slot />
    </main>

    <footer
      class="bg-[var(--color-earth-900)] text-white mt-16"
      role="contentinfo"
    >
      <div class="max-w-5xl mx-auto px-4 py-10 text-center">
        <p
          class="text-lg font-medium mb-2"
          style="font-family: var(--font-serif);"
        >
          Recetas de Abuela
        </p>
        <p class="text-sm text-stone-400 mb-4">
          Preservando la memoria culinaria de España, receta a receta.
        </p>
        <p class="text-xs text-stone-500">
          Contenido compartido con cariño. Hecho con
          <Heart size={14} aria-label="amor" class="inline-block align-middle text-red-400" /> y mucho aceite de oliva.
        </p>
      </div>
    </footer>
  </body>
</html>
