---
import '../styles/global.css';
import { UtensilsCrossed, Mic, Heart, Menu, X } from '@lucide/astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = 'Un tesoro de recetas tradicionales españolas, preservando la memoria culinaria de nuestras abuelas.',
  image,
  imageAlt = 'Recetas de Abuela — cocina tradicional española',
  type = 'website',
  jsonLd,
} = Astro.props;

const siteTitle = 'Recetas de Abuela';
const siteDescription = 'Un tesoro de recetas tradicionales españolas, preservando la memoria culinaria de nuestras abuelas.';
const fullTitle = title === siteTitle ? title : `${title} — ${siteTitle}`;

const siteBase = Astro.site ?? new URL('http://localhost:4321');
const canonicalURL = new URL(Astro.url.pathname, siteBase);

function toAbsoluteUrl(url: string | undefined): string {
  if (!url) return new URL('/og-default.jpg', siteBase).toString();
  if (url.startsWith('http://') || url.startsWith('https://')) return url;
  return new URL(url, siteBase).toString();
}
const ogImage = toAbsoluteUrl(image);

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteBase}#website`,
  name: siteTitle,
  description: siteDescription,
  url: siteBase.toString(),
  inLanguage: 'es-ES',
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content={siteTitle} />

    <!-- summary_large_image muestra la imagen grande al compartir -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body class="flex flex-col min-h-screen">
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

    <div
      id="dev-banner"
      role="status"
      aria-live="polite"
      class="bg-amber-100 border-b-2 border-amber-300 text-amber-900 text-sm no-print"
    >
      <div class="max-w-5xl mx-auto px-4 py-3 flex items-start justify-between gap-4">
        <p class="leading-snug">
          <strong class="font-bold">Sitio en desarrollo.</strong>
          Las recetas y perfiles de cocineras que aparecen ahora mismo han sido generados por IA como contenido de prueba.
          El contenido real, con recetas auténticas y sus protagonistas, se irá publicando próximamente.
        </p>
        <button
          type="button"
          id="close-dev-banner"
          class="flex-shrink-0 p-1 rounded-lg hover:bg-amber-200 transition-colors"
          aria-label="Cerrar aviso de desarrollo"
          style="min-width: 2rem; min-height: 2rem;"
        >
          <span aria-hidden="true" class="text-lg leading-none">×</span>
        </button>
      </div>
    </div>

    <script>
      const banner = document.getElementById('dev-banner');
      const closeBtn = document.getElementById('close-dev-banner');

      if (sessionStorage.getItem('devBannerClosed')) {
        banner?.classList.add('hidden');
      }

      closeBtn?.addEventListener('click', () => {
        banner?.classList.add('hidden');
        sessionStorage.setItem('devBannerClosed', '1');
      });

      const menuButton = document.getElementById('mobile-menu-button');
      const mobileMenu = document.getElementById('mobile-menu');
      const openIcon = document.getElementById('menu-icon-open');
      const closeIcon = document.getElementById('menu-icon-close');
      const mobileLinks = mobileMenu?.querySelectorAll('a');

      function toggleMenu() {
        const isExpanded = menuButton?.getAttribute('aria-expanded') === 'true';
        menuButton?.setAttribute('aria-expanded', (!isExpanded).toString());
        mobileMenu?.classList.toggle('hidden');
        openIcon?.classList.toggle('hidden');
        closeIcon?.classList.toggle('hidden');
        
        if (!isExpanded) {
          document.body.style.overflow = 'hidden'; // Evita scroll al estar abierto
        } else {
          document.body.style.overflow = '';
        }
      }

      menuButton?.addEventListener('click', toggleMenu);

      // Cerrar menú al hacer clic en un enlace (importante para SPAs o anchors)
      mobileLinks?.forEach(link => {
        link.addEventListener('click', () => {
          if (!mobileMenu?.classList.contains('hidden')) {
            toggleMenu();
          }
        });
      });

      window.addEventListener('resize', () => {
        if (window.innerWidth >= 768 && !mobileMenu?.classList.contains('hidden')) {
          toggleMenu();
        }
      });
    </script>

    <header
      class="bg-[var(--color-earth-900)] text-white shadow-lg sticky top-0 z-50"
      role="banner"
    >
      <div class="max-w-5xl mx-auto px-4">
        <div class="flex items-center justify-between py-2.5 sm:py-4 gap-2 sm:gap-4">
          <a
            href="/"
            class="flex items-center gap-2 sm:gap-3 hover:opacity-90 transition-opacity min-w-0 flex-shrink"
            aria-label="Recetas de Abuela — Ir a la página principal"
          >
            <UtensilsCrossed size={28} aria-hidden="true" class="text-amber-300 flex-shrink-0 sm:w-8 sm:h-8" />
            <div class="min-w-0">
              <span
                class="block text-lg sm:text-xl font-bold tracking-tight leading-tight truncate"
                style="font-family: var(--font-serif);"
              >
                Recetas de Abuela
              </span>
              <span class="block text-[9px] sm:text-xs text-amber-300 tracking-widest uppercase truncate">
                Cocina tradicional
              </span>
            </div>
          </a>

          <!-- Botón Menú Móvil -->
          <button
            type="button"
            id="mobile-menu-button"
            class="md:hidden flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg border border-white/20 hover:bg-white/10 transition-colors flex-shrink-0"
            aria-expanded="false"
            aria-controls="mobile-menu"
            aria-label="Abrir menú de navegación"
          >
            <span class="text-[10px] sm:text-xs font-black uppercase tracking-wider">Menú</span>
            <Menu size={20} id="menu-icon-open" aria-hidden="true" />
            <X size={20} id="menu-icon-close" aria-hidden="true" class="hidden" />
          </button>

          <nav class="hidden md:block" aria-label="Navegación principal">
            <ul class="flex items-center gap-1 list-none m-0 p-0 text-white">
              <li>
                <a
                  href="/"
                  class="px-4 py-2 rounded-lg text-sm font-medium hover:bg-white/10 transition-colors block"
                  aria-current={Astro.url.pathname === '/' ? 'page' : undefined}
                >
                  Recetas
                </a>
              </li>
              <li>
                <a
                  href="/sobre-el-proyecto"
                  class="px-4 py-2 rounded-lg text-sm font-medium hover:bg-white/10 transition-colors block"
                  aria-current={Astro.url.pathname === '/sobre-el-proyecto' ? 'page' : undefined}
                >
                  El Proyecto
                </a>
              </li>
              <li>
                <a
                  href="/sobre-el-proyecto#manda-tu-receta"
                  class="ml-2 flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-bold bg-[var(--color-terracotta-500)] hover:bg-[var(--color-terracotta-600)] text-white transition-colors"
                  style="min-height: var(--min-touch-target);"
                >
                  <Mic size={16} aria-hidden="true" />
                  ¡Manda tu receta!
                </a>
              </li>
            </ul>
          </nav>
        </div>

        <!-- Navegación Móvil (Desplegable) -->
        <nav
          id="mobile-menu"
          class="hidden md:hidden pb-8 border-t border-white/10 animate-in fade-in slide-in-from-top-2 duration-200"
          aria-label="Navegación móvil"
        >
          <ul class="flex flex-col gap-1 list-none m-0 p-0 pt-4">
            <li>
              <a
                href="/"
                class="px-4 py-4 rounded-xl text-xl font-bold hover:bg-white/10 transition-colors block active:bg-white/20"
                aria-current={Astro.url.pathname === '/' ? 'page' : undefined}
              >
                Recetas
              </a>
            </li>
            <li>
              <a
                href="/sobre-el-proyecto"
                class="px-4 py-4 rounded-xl text-xl font-bold hover:bg-white/10 transition-colors block active:bg-white/20"
                aria-current={Astro.url.pathname === '/sobre-el-proyecto' ? 'page' : undefined}
              >
                El Proyecto
              </a>
            </li>
            <li class="mt-4">
              <a
                href="/sobre-el-proyecto#manda-tu-receta"
                id="mobile-manda-tu-receta"
                class="flex items-center justify-center gap-3 px-4 py-6 rounded-2xl text-2xl font-black bg-[var(--color-terracotta-500)] hover:bg-[var(--color-terracotta-600)] text-white transition-all shadow-xl active:scale-[0.98]"
              >
                <Mic size={28} aria-hidden="true" />
                ¡Manda tu receta!
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <main id="main-content" tabindex="-1" class="flex-1">
      <slot />
    </main>

    <footer
      class="bg-[var(--color-earth-900)] text-white mt-16"
      role="contentinfo"
    >
      <div class="max-w-5xl mx-auto px-4 py-10 text-center">
        <p
          class="text-lg font-medium mb-2"
          style="font-family: var(--font-serif);"
        >
          Recetas de Abuela
        </p>
        <p class="text-sm text-stone-400 mb-4">
          Preservando la memoria culinaria de España, receta a receta.
        </p>
        <p class="text-xs text-stone-500">
          Contenido compartido con cariño. Hecho con
          <Heart size={14} aria-label="amor" class="inline-block align-middle text-red-400" /> y mucho aceite de oliva.
        </p>
      </div>
    </footer>
  </body>
</html>
